{
  "name": "my-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api run dev",
    "dev:app": "pnpm --filter app run dev",
    "dev:landing": "pnpm --filter landing run dev",
    "better-auth:generate": "pnpm --filter @myapp/auth run better-auth:generate",
    "db:push:local": "pnpm run --filter @myapp/db db:push:local",
    "db:push:remote": "pnpm run --filter @myapp/db db:push:remote",
    "db:studio:local": "pnpm run --filter @myapp/db db:studio:local",
    "db:studio:remote": "pnpm run --filter @myapp/db db:studio:remote",
    "codegen": "pnpm --filter @myapp/api-spec run codegen",
    "test:api": "pnpm --filter api run test",
    "test:api:watch": "pnpm --filter api run test:watch",
    "test:e2e": "pnpm --filter app run test:e2e",
    "test:e2e:ui": "pnpm --filter app run test:e2e:ui",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "typescript": "~5.9.3"
  }
}
