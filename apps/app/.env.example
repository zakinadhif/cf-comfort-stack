# Copy to .env.local and adjust as needed.
# This file is safe to commit. .env.local is gitignored by Vite.

# Base URL passed to the Better Auth client (must match BETTER_AUTH_URL in apps/api/.dev.vars)
VITE_APP_URL=http://localhost:5173

# Override the API target for the Vite dev proxy (defaults to http://127.0.0.1:8787)
# VITE_API_DEV_TARGET=http://127.0.0.1:8787
